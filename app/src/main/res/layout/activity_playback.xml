<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#172554"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_artwork"
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_gravity="top"
            android:adjustViewBounds="true"
            android:background="#25324A"
            android:padding="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="24dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_playback_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="歌曲：暂无播放内容"
                android:textColor="#EAF2FF"
                android:textSize="34sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="@font/misans_bold" />

            <TextView
                android:id="@+id/tv_playback_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="艺术家：-"
                android:textColor="#CBD5E1"
                android:textSize="20sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/misans_regular" />

            <TextView
                android:id="@+id/tv_playback_album"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="专辑：-"
                android:textColor="#CBD5E1"
                android:textSize="20sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/misans_regular" />

            <TextView
                android:id="@+id/tv_playback_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="00:00 / 00:00"
                android:textColor="#EAF2FF"
                android:textSize="18sp"
                android:fontFamily="@font/misans_medium" />

            <ProgressBar
                android:id="@+id/pb_playback"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="6dp"
                android:progressTint="#34D399"
                android:progressBackgroundTint="#334155"
                android:max="1000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="歌词："
                android:textColor="#60A5FA"
                android:textSize="20sp"
                android:fontFamily="@font/misans_bold" />

            <TextView
                android:id="@+id/tv_lyric_prev"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#94A3B8"
                android:textSize="20sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/misans_regular" />

            <TextView
                android:id="@+id/tv_lyric_current"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#EAF2FF"
                android:textStyle="bold"
                android:textSize="24sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/misans_bold" />

            <TextView
                android:id="@+id/tv_lyric_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#94A3B8"
                android:textSize="20sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/misans_regular" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_prev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="120dp"
            android:text="上一首"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_button_dark"
            android:fontFamily="@font/misans_medium" />

        <Button
            android:id="@+id/btn_play_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:minWidth="120dp"
            android:text="播放"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_button_green"
            android:fontFamily="@font/misans_medium" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:minWidth="120dp"
            android:text="下一首"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_button_dark"
            android:fontFamily="@font/misans_medium" />

        <Button
            android:id="@+id/btn_lyrics_fullscreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:minWidth="140dp"
            android:text="歌词全屏"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/bg_button_primary"
            android:fontFamily="@font/misans_medium" />

        <Button
            android:id="@+id/btn_back_to_browser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:minWidth="150dp"
            android:text="返回文件页"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/bg_button_primary"
            android:fontFamily="@font/misans_medium" />
    </LinearLayout>

</LinearLayout>
